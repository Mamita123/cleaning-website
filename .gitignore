# Never push node_modules — too large
node_modules/
*/node_modules/

# Never push build outputs
*/build/
*/dist/

# Never push environment files — contains passwords!
.env
*/.env
backend/.env

# Never push OS files
.DS_Store
Thumbs.db
Desktop.ini

# Never push log files
*.log
npm-debug.log*

# Never push VS Code settings
.vscode/